# LAWAI Backend Environment Variables
# Copy this to .env and fill in values

# ===== REQUIRED =====
# Get free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ===== OPTIONAL (defaults shown) =====
# MongoDB connection string (local MongoDB or Atlas M0 free tier)
MONGO_URI=mongodb://localhost:27017/lawai

# JWT secret key - change this in production!
JWT_SECRET_KEY=lawai-super-secret-key-change-in-production-2024

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=1

# ChromaDB storage location
CHROMA_PERSIST_DIR=./chroma_db

# Corpus directory
CORPUS_DIR=./data/corpus

# ===== GETTING STARTED =====
# 1. Copy this file: cp .env.example .env
# 2. Get Gemini API key from https://aistudio.google.com/app/apikey (free, no credit card)
# 3. Install dependencies: pip install -r requirements.txt
# 4. Start MongoDB (or skip for chat-without-history mode)
# 5. Ingest corpus: python scripts/ingest_corpus.py
# 6. Start server: python main.py
