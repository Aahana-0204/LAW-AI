# =============================================
#  LAWAI Backend — Environment Variables
# =============================================

# --- LLM Backend ---
# "ollama" = local Ollama server (for local dev)
# "local"  = llama-cpp-python GGUF (for HuggingFace Spaces — no API, no credit card)
LLM_BACKEND=ollama

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Local GGUF model (used when LLM_BACKEND=local)
LLM_MODEL_REPO=Qwen/Qwen2.5-3B-Instruct-GGUF
LLM_MODEL_FILE=qwen2.5-3b-instruct-q4_k_m.gguf
LLM_THREADS=2
LLM_N_CTX=4096

# Database (optional)
MONGO_URI=mongodb://localhost:27017/lawai

# Auth
JWT_SECRET_KEY=change-this-to-a-long-random-string

# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# Storage
CHROMA_PERSIST_DIR=./chroma_db
CORPUS_DIR=./data/corpus

# CORS — add your Vercel URL for production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
