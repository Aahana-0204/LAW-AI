{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    }
  ],
  "functions": {
    "backend/main.py": {
      "maxDuration": 60
    }
  },
  "env": {
    "LLM_BACKEND": "hf_api",
    "HF_MODEL": "Qwen/Qwen2.5-72B-Instruct",
    "FLASK_ENV": "production"
  }
}
